{
  "name": "photobooth-platform",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.7.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "dev:booth": "turbo dev --filter=@photobooth/booth-desktop",
    "dev:admin": "turbo dev --filter=@photobooth/admin-web",
    "dev:api": "turbo dev --filter=@photobooth/api",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "format": "prettier --write .",
    "seed": "node ./scripts/seed-local.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "prettier": "^3.5.3",
    "turbo": "^2.5.0",
    "typescript": "^5.8.3"
  }
}
