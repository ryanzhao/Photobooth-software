{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Photobooth Booth",
  "version": "0.1.0",
  "identifier": "com.rocket.photobooth.booth",
  "build": {
    "beforeDevCommand": "pnpm --filter @photobooth/booth-desktop dev",
    "beforeBuildCommand": "pnpm --filter @photobooth/booth-desktop build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Photobooth Booth",
        "width": 1600,
        "height": 980,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "dmg"],
    "shortDescription": "Local-first photobooth booth operator application",
    "category": "Photography"
  }
}
