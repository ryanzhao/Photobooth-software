<Window x:Class="Photobooth.BoothNative.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Photobooth Native Booth"
        Width="1540"
        Height="920"
        MinWidth="1280"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource SurfaceBrush}">
    <Grid Margin="22">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.8*" />
            <ColumnDefinition Width="0.95*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.ColumnSpan="2"
                Background="{StaticResource SurfaceElevatedBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="22"
                Padding="24"
                Margin="0,0,0,18">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock x:Name="HeaderTitleText" Text="Photobooth Native Booth" FontSize="32" FontWeight="SemiBold" />
                    <TextBlock x:Name="HeaderSubtitleText"
                               Margin="0,8,0,0"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="14" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="LanguageLabelText" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{StaticResource TextMutedBrush}" Text="Language" />
                    <ComboBox x:Name="LanguageCombo"
                              Width="120"
                              Margin="0,0,12,0"
                              SelectionChanged="LanguageCombo_SelectionChanged">
                        <ComboBoxItem Tag="zh-CN" Content="Chinese" />
                        <ComboBoxItem Tag="en-US" Content="English" />
                    </ComboBox>
                    <Button x:Name="RefreshDevicesButton" Click="RefreshDevicesButton_Click" />
                    <Button x:Name="CreateSessionButton" Click="CreateSessionButton_Click" Background="{StaticResource AccentStrongBrush}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Grid.Column="0" Margin="0,0,18,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="1.55*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="0.92*" />
            </Grid.RowDefinitions>

            <Border Background="{StaticResource SurfaceElevatedBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="24"
                    Padding="26">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="StageTitleText" FontSize="22" FontWeight="SemiBold" />
                        <TextBlock x:Name="StageSubtitleText"
                                   Margin="0,8,0,0"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <Border Grid.Row="1"
                            Margin="0,20,0,0"
                            CornerRadius="32"
                            Background="{StaticResource PanelSoftBrush}"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            Padding="18">
                        <Grid x:Name="LivePreviewViewport" SizeChanged="LivePreviewViewport_SizeChanged">
                            <Border x:Name="LivePreviewFrame"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    CornerRadius="28"
                                    Background="{StaticResource PanelBrush}"
                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                    BorderThickness="1">
                                <Grid ClipToBounds="True">
                                    <Image x:Name="LivePreviewImage"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed" />
                                    <StackPanel x:Name="LivePreviewPlaceholder" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="560">
                                        <TextBlock x:Name="LivePreviewWaitingText" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                        <TextBlock x:Name="RuntimeStatusText"
                                                   Margin="0,10,0,0"
                                                   FontSize="16"
                                                   Foreground="{StaticResource AccentStrongBrush}"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap" />
                                        <TextBlock x:Name="LivePreviewHintText"
                                                   Margin="0,10,0,0"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource TextMutedBrush}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <UniformGrid Grid.Row="1" Margin="0,18,0,18" Columns="4">
                <Border Background="{StaticResource SurfaceElevatedBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="18" Margin="0,0,12,0" Padding="16">
                    <StackPanel>
                        <TextBlock x:Name="ModeStatLabelText" Foreground="{StaticResource TextMutedBrush}" FontSize="12" />
                        <TextBlock x:Name="ModeStatText" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource SurfaceElevatedBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="18" Margin="0,0,12,0" Padding="16">
                    <StackPanel>
                        <TextBlock x:Name="ShotsStatLabelText" Foreground="{StaticResource TextMutedBrush}" FontSize="12" />
                        <TextBlock x:Name="ShotsStatText" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource SurfaceElevatedBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="18" Margin="0,0,12,0" Padding="16">
                    <StackPanel>
                        <TextBlock x:Name="CountdownStatLabelText" Foreground="{StaticResource TextMutedBrush}" FontSize="12" />
                        <TextBlock x:Name="CountdownStatText" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource SurfaceElevatedBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="18" Padding="16">
                    <StackPanel>
                        <TextBlock x:Name="TemplateStatLabelText" Foreground="{StaticResource TextMutedBrush}" FontSize="12" />
                        <TextBlock x:Name="TemplateStatText" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.02*" />
                    <ColumnDefinition Width="1.12*" />
                    <ColumnDefinition Width="0.9*" />
                </Grid.ColumnDefinitions>
                <Border Background="{StaticResource SurfaceElevatedBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="24" Padding="20" Margin="0,0,18,0">
                    <DockPanel>
                        <TextBlock x:Name="RecentSessionsTitleText" DockPanel.Dock="Top" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,14" />
                        <ListBox x:Name="RecentSessionsList"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{StaticResource TextBrush}"
                                 SelectionChanged="RecentSessionsList_SelectionChanged" />
                    </DockPanel>
                </Border>
                <Border Grid.Column="1" Background="{StaticResource SurfaceElevatedBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="24" Padding="20" Margin="0,0,18,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="170" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="PhotoGalleryTitleText" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,14" />
                        <Border Grid.Row="1" CornerRadius="18" Background="{StaticResource PanelSoftBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="10">
                            <Grid>
                                <Image x:Name="GalleryPreviewImage" Stretch="Uniform" Visibility="Collapsed" />
                                <TextBlock x:Name="GalleryEmptyText" TextAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}" Margin="20" />
                            </Grid>
                        </Border>
                        <ListBox Grid.Row="2"
                                 x:Name="GalleryList"
                                 Margin="0,14,0,0"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{StaticResource TextBrush}"
                                 SelectionChanged="GalleryList_SelectionChanged" />
                    </Grid>
                </Border>
                <Border Grid.Column="2" Background="{StaticResource SurfaceElevatedBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="24" Padding="20">
                    <DockPanel>
                        <TextBlock x:Name="TemplatePackTitleText" DockPanel.Dock="Top" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,14" />
                        <TextBlock x:Name="SelectedTemplateText"
                                   DockPanel.Dock="Top"
                                   Margin="0,0,0,12"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="TemplateProgressText"
                                   DockPanel.Dock="Top"
                                   Margin="0,0,0,12"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   TextWrapping="Wrap" />
                        <UniformGrid DockPanel.Dock="Top" Columns="2" Margin="0,0,0,12">
                            <Button x:Name="PreviousTemplateButton" Click="PreviousTemplateButton_Click" Margin="0,0,8,8" MinHeight="44" />
                            <Button x:Name="NextTemplateButton" Click="NextTemplateButton_Click" Margin="0,0,0,8" MinHeight="44" />
                            <Button x:Name="RetakeLastSlotButton" Click="RetakeLastSlotButton_Click" Margin="0,0,8,0" MinHeight="44" />
                            <Button x:Name="ResetTemplateBoardButton" Click="ResetTemplateBoardButton_Click" MinHeight="44" />
                        </UniformGrid>
                        <Border DockPanel.Dock="Top"
                                Height="180"
                                Margin="0,0,0,12"
                                CornerRadius="18"
                                Background="{StaticResource PanelSoftBrush}"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1"
                                Padding="10">
                            <Grid>
                                <Image x:Name="TemplatePreviewImage" Stretch="Uniform" Visibility="Collapsed" />
                                <TextBlock x:Name="TemplatePreviewEmptyText"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Margin="20" />
                            </Grid>
                        </Border>
                        <Button x:Name="RenderTemplateButton"
                                DockPanel.Dock="Bottom"
                                Margin="0,12,0,0"
                                Click="RenderTemplateButton_Click"
                                Background="{StaticResource AccentStrongBrush}"
                                MinHeight="48" />
                        <ListBox x:Name="TemplateList"
                                 MaxHeight="180"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{StaticResource TextBrush}"
                                 SelectionChanged="TemplateList_SelectionChanged" />
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="1" Grid.Column="1" Background="{StaticResource SurfaceElevatedBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="24" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock x:Name="ControlsTitleText" FontSize="22" FontWeight="SemiBold" />
                    <TextBlock x:Name="ControlsSubtitleText"
                               Margin="0,8,0,0"
                               Foreground="{StaticResource TextMutedBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,24,0,0">
                    <TextBlock x:Name="CaptureModeLabelText" Foreground="{StaticResource TextMutedBrush}" />
                    <ComboBox x:Name="CaptureModeCombo" SelectedIndex="1" Margin="0,8,0,0" Background="{StaticResource ControlBackgroundBrush}">
                        <ComboBoxItem Tag="single" />
                        <ComboBoxItem Tag="multi" />
                        <ComboBoxItem Tag="burst" />
                    </ComboBox>
                    <TextBlock x:Name="ShotCountLabelText" Foreground="{StaticResource TextMutedBrush}" Margin="0,16,0,0" />
                    <TextBox x:Name="ShotCountTextBox" Text="3" Margin="0,8,0,0" />
                    <TextBlock x:Name="CountdownLabelText" Foreground="{StaticResource TextMutedBrush}" Margin="0,16,0,0" />
                    <TextBox x:Name="CountdownTextBox" Text="3" Margin="0,8,0,0" />
                </StackPanel>

                <ScrollViewer Grid.Row="2" Margin="0,20,0,0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <WrapPanel>
                            <Button x:Name="LaunchDigiCamControlButton" Click="LaunchDigiCamControlButton_Click" Margin="0,0,12,12" />
                            <Button x:Name="StartLiveButton" Click="StartLiveButton_Click" Margin="0,0,12,12" />
                            <Button x:Name="CaptureNowButton" Click="CaptureNowButton_Click" Background="{StaticResource AccentStrongBrush}" Margin="0,0,12,12" />
                            <Button x:Name="AutoFocusButton" Click="AutoFocusButton_Click" Margin="0,0,12,12" />
                            <Button x:Name="OpenSessionFolderButton" Click="OpenSessionFolderButton_Click" Margin="0,0,0,12" />
                        </WrapPanel>

                        <Border Background="{StaticResource PanelSoftBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="18" Padding="14" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock x:Name="ActiveSessionLabelText" Foreground="{StaticResource TextMutedBrush}" FontSize="12" />
                                <TextBlock x:Name="ActiveSessionText" Margin="0,6,0,0" FontWeight="SemiBold" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <TextBlock x:Name="CameraParametersTitleText" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                        <TextBlock x:Name="IsoLabelText" Foreground="{StaticResource TextMutedBrush}" />
                        <ComboBox x:Name="IsoComboBox" Margin="0,6,0,12" SelectionChanged="ParameterComboBox_SelectionChanged" Tag="iso" />
                        <TextBlock x:Name="ShutterLabelText" Foreground="{StaticResource TextMutedBrush}" />
                        <ComboBox x:Name="ShutterComboBox" Margin="0,6,0,12" SelectionChanged="ParameterComboBox_SelectionChanged" Tag="shutterspeed" />
                        <TextBlock x:Name="ApertureLabelText" Foreground="{StaticResource TextMutedBrush}" />
                        <ComboBox x:Name="ApertureComboBox" Margin="0,6,0,12" SelectionChanged="ParameterComboBox_SelectionChanged" Tag="aperture" />
                        <TextBlock x:Name="WhiteBalanceLabelText" Foreground="{StaticResource TextMutedBrush}" />
                        <ComboBox x:Name="WhiteBalanceComboBox" Margin="0,6,0,12" SelectionChanged="ParameterComboBox_SelectionChanged" Tag="whitebalance" />
                        <TextBlock x:Name="ExposureCompLabelText" Foreground="{StaticResource TextMutedBrush}" />
                        <ComboBox x:Name="ExposureCompComboBox" Margin="0,6,0,0" SelectionChanged="ParameterComboBox_SelectionChanged" Tag="exposurecompensation" />
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="3" Margin="0,20,0,0">
                    <TextBlock x:Name="DetectedDevicesTitleText" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock x:Name="DeviceSummaryText"
                               Margin="0,6,0,0"
                               Foreground="{StaticResource TextMutedBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>

                <ListBox Grid.Row="4"
                         x:Name="DevicesList"
                         Margin="0,18,0,0"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{StaticResource TextBrush}" />
            </Grid>
        </Border>
    </Grid>
</Window>

