<Application x:Class="Photobooth.BoothNative.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#F7F2E8" />
        <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="#FFFDF8" />
        <SolidColorBrush x:Key="PanelBrush" Color="#EFE6D6" />
        <SolidColorBrush x:Key="PanelSoftBrush" Color="#F6EFE4" />
        <SolidColorBrush x:Key="AccentBrush" Color="#C9A46A" />
        <SolidColorBrush x:Key="AccentStrongBrush" Color="#B8894E" />
        <SolidColorBrush x:Key="TextBrush" Color="#4E4032" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#897765" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#DCCFBE" />
        <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#FFFCF7" />
        <SolidColorBrush x:Key="ControlForegroundBrush" Color="#4E4032" />

        <Style TargetType="Window">
            <Setter Property="TextElement.Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#FFFDF8" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource ControlForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,8" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource ControlForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
        </Style>
    </Application.Resources>
</Application>
