<Window x:Class="Photobooth.BoothNative.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Photobooth Native Booth 9:16"
        Width="1280"
        Height="900"
        MinWidth="1100"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource SurfaceBrush}">
    <Grid x:Name="RootLayoutGrid" Margin="22">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="MainColumnLeft" Width="2.8*" />
            <ColumnDefinition x:Name="MainColumnRight" Width="0.95*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition x:Name="MainControlsRow" Height="0" />
        </Grid.RowDefinitions>

        <Border Grid.ColumnSpan="2"
                Background="{StaticResource SurfaceElevatedBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="22"
                Padding="24"
                Margin="0,0,0,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="240" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock x:Name="HeaderTitleText" Text="Photobooth Native Booth 9:16" FontSize="32" FontWeight="SemiBold" />
                    <TextBlock x:Name="HeaderSubtitleText"
                               Margin="0,8,0,0"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="14"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <ScrollViewer Grid.Column="1"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              MaxWidth="620"
                              VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock x:Name="LanguageLabelText" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{StaticResource TextMutedBrush}" Text="Language" />
                        <ComboBox x:Name="LanguageCombo"
                                  Width="120"
                                  Margin="0,0,12,0"
                                  SelectionChanged="LanguageCombo_SelectionChanged">
                            <ComboBoxItem Tag="zh-CN" Content="Chinese" />
                            <ComboBoxItem Tag="en-US" Content="English" />
                        </ComboBox>
                        <Button x:Name="ToggleOrientationButton"
                                Click="ToggleOrientationButton_Click"
                                Margin="0,0,12,0"
                                MinWidth="120" />
                        <Button x:Name="RefreshDevicesButton" Click="RefreshDevicesButton_Click" Margin="0,0,12,0" MinWidth="110" />
                        <Button x:Name="CreateSessionButton" Click="CreateSessionButton_Click" Background="{StaticResource AccentStrongBrush}" MinWidth="140" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <Grid x:Name="MainStagePane" Grid.Row="1" Grid.Column="0" Margin="0,0,18,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="2.4*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="0.75*" />
            </Grid.RowDefinitions>

            <Border Background="{StaticResource SurfaceElevatedBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="24"
                    Padding="26">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="StageTitleText" FontSize="22" FontWeight="SemiBold" />
                        <TextBlock x:Name="StageSubtitleText"
                                   Margin="0,8,0,0"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   TextWrapping="Wrap" />
                        <WrapPanel Margin="0,14,0,0">
                            <Button x:Name="UploadStageButton" Click="UploadPhotosButton_Click" Margin="0,0,12,0" MinHeight="40" MinWidth="150" />
                            <Button x:Name="FullscreenPreviewButton" Click="FullscreenPreviewButton_Click" Margin="0,0,12,0" MinHeight="40" MinWidth="150" />
                            <Button x:Name="ClearPreviewButton" Click="ClearPreviewButton_Click" MinHeight="40" MinWidth="150" />
                        </WrapPanel>
                    </StackPanel>
                    <Border Grid.Row="1"
                            Margin="0,20,0,0"
                            CornerRadius="32"
                            Background="{StaticResource PanelSoftBrush}"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            Padding="18">
                        <Grid x:Name="LivePreviewViewport" SizeChanged="LivePreviewViewport_SizeChanged">
                            <Border x:Name="LivePreviewFrame"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    CornerRadius="28"
                                    Background="{StaticResource PanelBrush}"
                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                    BorderThickness="1">
                                <Grid ClipToBounds="True">
                                    <Image x:Name="LivePreviewImage"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed" />
                                    <Image x:Name="LiveGuideOverlayImage"
                                           Stretch="Fill"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Stretch"
                                           IsHitTestVisible="False"
                                           Opacity="0.72"
                                           Visibility="Collapsed" />
                                    <StackPanel x:Name="LivePreviewPlaceholder" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="560">
                                        <TextBlock x:Name="LivePreviewWaitingText" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                        <TextBlock x:Name="RuntimeStatusText"
                                                   Margin="0,10,0,0"
                                                   FontSize="16"
                                                   Foreground="{StaticResource AccentStrongBrush}"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap" />
                                        <TextBlock x:Name="LivePreviewHintText"
                                                   Margin="0,10,0,0"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource TextMutedBrush}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <UniformGrid Grid.Row="1" Margin="0,18,0,18" Columns="4">
                <Border Background="{StaticResource SurfaceElevatedBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="18" Margin="0,0,12,0" Padding="16">
                    <StackPanel>
                        <TextBlock x:Name="ModeStatLabelText" Foreground="{StaticResource TextMutedBrush}" FontSize="12" />
                        <TextBlock x:Name="ModeStatText" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource SurfaceElevatedBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="18" Margin="0,0,12,0" Padding="16">
                    <StackPanel>
                        <TextBlock x:Name="ShotsStatLabelText" Foreground="{StaticResource TextMutedBrush}" FontSize="12" />
                        <TextBlock x:Name="ShotsStatText" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource SurfaceElevatedBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="18" Margin="0,0,12,0" Padding="16">
                    <StackPanel>
                        <TextBlock x:Name="CountdownStatLabelText" Foreground="{StaticResource TextMutedBrush}" FontSize="12" />
                        <TextBlock x:Name="CountdownStatText" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource SurfaceElevatedBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="18" Padding="16">
                    <StackPanel>
                        <TextBlock x:Name="TemplateStatLabelText" Foreground="{StaticResource TextMutedBrush}" FontSize="12" />
                        <TextBlock x:Name="TemplateStatText" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.02*" />
                    <ColumnDefinition Width="1.12*" />
                    <ColumnDefinition Width="0.9*" />
                </Grid.ColumnDefinitions>
                <Border Background="{StaticResource SurfaceElevatedBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="24" Padding="20" Margin="0,0,18,0">
                    <DockPanel>
                        <TextBlock x:Name="RecentSessionsTitleText" DockPanel.Dock="Top" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,14" />
                        <ListBox x:Name="RecentSessionsList"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{StaticResource TextBrush}"
                                 SelectionChanged="RecentSessionsList_SelectionChanged" />
                    </DockPanel>
                </Border>
                <Border Grid.Column="1" Background="{StaticResource SurfaceElevatedBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="24" Padding="20" Margin="0,0,18,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="170" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="PhotoGalleryTitleText" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,14" />
                        <Border Grid.Row="1" CornerRadius="18" Background="{StaticResource PanelSoftBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="10">
                            <Grid>
                                <Image x:Name="GalleryPreviewImage" Stretch="Uniform" Visibility="Collapsed" />
                                <TextBlock x:Name="GalleryEmptyText" TextAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}" Margin="20" />
                            </Grid>
                        </Border>
                        <ListBox Grid.Row="2"
                                 x:Name="GalleryList"
                                 Margin="0,14,0,0"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{StaticResource TextBrush}"
                                 SelectionMode="Extended"
                                 SelectionChanged="GalleryList_SelectionChanged" />
                    </Grid>
                </Border>
                <Border Grid.Column="2" Background="{StaticResource SurfaceElevatedBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="24" Padding="20">
                    <DockPanel>
                        <TextBlock x:Name="TemplatePackTitleText" DockPanel.Dock="Top" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,14" />
                        <TextBlock x:Name="SelectedTemplateText"
                                   DockPanel.Dock="Top"
                                   Margin="0,0,0,12"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="TemplateProgressText"
                                   DockPanel.Dock="Top"
                                   Margin="0,0,0,12"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   TextWrapping="Wrap" />
                        <UniformGrid DockPanel.Dock="Top" Columns="2" Margin="0,0,0,12">
                            <Button x:Name="PreviousTemplateButton" Click="PreviousTemplateButton_Click" Margin="0,0,8,8" MinHeight="44" />
                            <Button x:Name="NextTemplateButton" Click="NextTemplateButton_Click" Margin="0,0,0,8" MinHeight="44" />
                            <Button x:Name="RetakeLastSlotButton" Click="RetakeLastSlotButton_Click" Margin="0,0,8,0" MinHeight="44" />
                            <Button x:Name="ResetTemplateBoardButton" Click="ResetTemplateBoardButton_Click" MinHeight="44" />
                        </UniformGrid>
                        <Border DockPanel.Dock="Top"
                                Height="180"
                                Margin="0,0,0,12"
                                CornerRadius="18"
                                Background="{StaticResource PanelSoftBrush}"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1"
                                Padding="10">
                            <Grid>
                                <Image x:Name="TemplatePreviewImage" Stretch="Uniform" Visibility="Collapsed" MouseLeftButtonUp="TemplatePreviewImage_MouseLeftButtonUp" />
                                <TextBlock x:Name="TemplatePreviewEmptyText"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Margin="20" />
                            </Grid>
                        </Border>
                        <Button x:Name="RenderTemplateButton"
                                DockPanel.Dock="Bottom"
                                Margin="0,12,0,0"
                                Click="RenderTemplateButton_Click"
                                Background="{StaticResource AccentStrongBrush}"
                                MinHeight="48" />
                        <ListBox x:Name="TemplateList"
                                 MaxHeight="180"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{StaticResource TextBrush}"
                                 SelectionChanged="TemplateList_SelectionChanged" />
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>

        <ScrollViewer x:Name="MainControlsPane"
                      Grid.Row="1"
                      Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      PanningMode="VerticalOnly">
        <Border Background="{StaticResource SurfaceElevatedBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="24" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock x:Name="ControlsTitleText" FontSize="22" FontWeight="SemiBold" />
                    <TextBlock x:Name="ControlsSubtitleText"
                               Margin="0,8,0,0"
                               Foreground="{StaticResource TextMutedBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,24,0,0">
                    <TextBlock x:Name="CaptureModeLabelText" Foreground="{StaticResource TextMutedBrush}" />
                    <ComboBox x:Name="CaptureModeCombo" SelectedIndex="1" Margin="0,8,0,0" Background="{StaticResource ControlBackgroundBrush}">
                        <ComboBoxItem Tag="single" />
                        <ComboBoxItem Tag="multi" />
                        <ComboBoxItem Tag="burst" />
                    </ComboBox>
                    <TextBlock x:Name="SourceModeLabelText" Foreground="{StaticResource TextMutedBrush}" Margin="0,16,0,0" />
                    <ComboBox x:Name="SourceModeComboBox" Margin="0,8,0,0" SelectionChanged="SourceModeComboBox_SelectionChanged">
                        <ComboBoxItem Tag="Camera" />
                        <ComboBoxItem Tag="Upload" />
                        <ComboBoxItem Tag="Gallery" />
                    </ComboBox>
                    <TextBlock x:Name="ShotCountLabelText" Foreground="{StaticResource TextMutedBrush}" Margin="0,16,0,0" />
                    <TextBox x:Name="ShotCountTextBox" Text="3" Margin="0,8,0,0" />
                    <TextBlock x:Name="CountdownLabelText" Foreground="{StaticResource TextMutedBrush}" Margin="0,16,0,0" />
                    <TextBox x:Name="CountdownTextBox" Text="3" Margin="0,8,0,0" />
                    <TextBlock x:Name="BeautyLevelLabelText" Foreground="{StaticResource TextMutedBrush}" Margin="0,16,0,0" />
                    <ComboBox x:Name="BeautyLevelComboBox" Margin="0,8,0,0" SelectionChanged="BeautyLevelComboBox_SelectionChanged">
                        <ComboBoxItem Tag="Off" />
                        <ComboBoxItem Tag="Low" />
                        <ComboBoxItem Tag="Medium" />
                        <ComboBoxItem Tag="High" />
                    </ComboBox>
                    <TextBlock x:Name="FrameLabelText" Foreground="{StaticResource TextMutedBrush}" Margin="0,16,0,0" />
                    <ComboBox x:Name="FrameComboBox" Margin="0,8,0,0" SelectionChanged="FrameComboBox_SelectionChanged" />
                    <TextBlock x:Name="EffectPresetLabelText" Foreground="{StaticResource TextMutedBrush}" Margin="0,16,0,0" />
                    <ComboBox x:Name="EffectPresetComboBox" Margin="0,8,0,0" SelectionChanged="EffectPresetComboBox_SelectionChanged" />
                    <TextBlock x:Name="AssignmentModeLabelText" Foreground="{StaticResource TextMutedBrush}" Margin="0,16,0,0" />
                    <ComboBox x:Name="AssignmentModeComboBox" Margin="0,8,0,0" SelectionChanged="AssignmentModeComboBox_SelectionChanged">
                        <ComboBoxItem Tag="auto" />
                        <ComboBoxItem Tag="manual" />
                    </ComboBox>
                </StackPanel>

                <Border Grid.Row="2"
                        x:Name="ImportDropZone"
                        Background="{StaticResource PanelSoftBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="14"
                        Margin="0,20,0,0"
                        AllowDrop="True"
                        DragOver="ImportDropZone_DragOver"
                        Drop="ImportDropZone_Drop">
                    <StackPanel>
                        <TextBlock x:Name="ImportModeTitleText" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock x:Name="ImportModeHintText"
                                   Margin="0,6,0,12"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="ImportDropHintText"
                                   Margin="0,0,0,12"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   TextWrapping="Wrap" />
                        <WrapPanel Margin="0,0,0,4">
                            <Button x:Name="UploadPhotosButton" Click="UploadPhotosButton_Click" Margin="0,0,12,12" MinWidth="160" />
                            <Button x:Name="UseGallerySelectionButton" Click="UseGallerySelectionButton_Click" Margin="0,0,0,12" MinWidth="200" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Row="3"
                        Background="{StaticResource PanelSoftBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="14"
                        Margin="0,20,0,0">
                    <StackPanel>
                        <TextBlock x:Name="CameraParametersTitleText" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                        <WrapPanel>
                            <Button x:Name="LaunchDigiCamControlButton" Click="LaunchDigiCamControlButton_Click" Margin="0,0,12,12" MinWidth="150" MinHeight="42" />
                            <Button x:Name="StartLiveButton" Click="StartLiveButton_Click" Margin="0,0,12,12" MinWidth="120" MinHeight="42" />
                            <Button x:Name="CaptureNowButton" Click="CaptureNowButton_Click" Background="{StaticResource AccentStrongBrush}" Margin="0,0,12,12" MinWidth="120" MinHeight="42" />
                            <Button x:Name="AutoFocusButton" Click="AutoFocusButton_Click" Margin="0,0,0,12" MinWidth="120" MinHeight="42" />
                        </WrapPanel>
                        <UniformGrid Columns="2" Margin="0,0,0,12">
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock x:Name="IsoLabelText" Foreground="{StaticResource TextMutedBrush}" />
                                <ComboBox x:Name="IsoComboBox" Margin="0,6,0,0" SelectionChanged="ParameterComboBox_SelectionChanged" Tag="iso" />
                            </StackPanel>
                            <StackPanel Margin="8,0,0,0">
                                <TextBlock x:Name="ShutterLabelText" Foreground="{StaticResource TextMutedBrush}" />
                                <ComboBox x:Name="ShutterComboBox" Margin="0,6,0,0" SelectionChanged="ParameterComboBox_SelectionChanged" Tag="shutterspeed" />
                            </StackPanel>
                        </UniformGrid>
                        <TextBlock x:Name="StickerLabelText" Foreground="{StaticResource TextMutedBrush}" />
                        <ComboBox x:Name="StickerComboBox" Margin="0,6,0,12" SelectionChanged="StickerComboBox_SelectionChanged">
                            <ComboBoxItem Tag="None" />
                            <ComboBoxItem Tag="DogEars" />
                            <ComboBoxItem Tag="PartyHat" />
                            <ComboBoxItem Tag="Hearts" />
                        </ComboBox>
                        <TextBlock x:Name="MaskModeLabelText" Foreground="{StaticResource TextMutedBrush}" />
                        <ComboBox x:Name="MaskModeComboBox" Margin="0,6,0,0" SelectionChanged="MaskModeComboBox_SelectionChanged">
                            <ComboBoxItem Tag="None" />
                            <ComboBoxItem Tag="LeftHalf" />
                            <ComboBoxItem Tag="RightHalf" />
                            <ComboBoxItem Tag="CenterSpotlight" />
                        </ComboBox>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="4" Margin="0,20,0,0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <WrapPanel>
                            <Button x:Name="OpenSessionFolderButton" Click="OpenSessionFolderButton_Click" Margin="0,0,0,12" />
                        </WrapPanel>

                        <WrapPanel Margin="0,0,0,12">
                            <Button x:Name="OpenFinalButton" Click="OpenFinalButton_Click" Margin="0,0,12,12" MinWidth="140" />
                            <Button x:Name="PrintFinalButton" Click="PrintFinalButton_Click" Margin="0,0,12,12" MinWidth="140" />
                            <Button x:Name="UploadToWebsiteButton" Click="UploadToWebsiteButton_Click" Margin="0,0,12,12" MinWidth="140" />
                            <Button x:Name="RestartSessionButton" Click="RestartSessionButton_Click" Margin="0,0,0,12" MinWidth="140" />
                        </WrapPanel>

                        <Border Background="{StaticResource PanelSoftBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="16" Padding="12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock x:Name="WebsiteUploadTitleText" FontSize="16" FontWeight="SemiBold" />
                                <TextBlock x:Name="WebsiteUploadHintText" Margin="0,6,0,10" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" />

                                <TextBlock x:Name="WebsiteBaseUrlLabelText" Foreground="{StaticResource TextMutedBrush}" />
                                <TextBox x:Name="WebsiteBaseUrlTextBox" Margin="0,6,0,10" Text="http://localhost:3000" />

                                <TextBlock x:Name="WebsiteCodeLabelText" Foreground="{StaticResource TextMutedBrush}" />
                                <TextBox x:Name="WebsiteCodeTextBox" Margin="0,6,0,10" />

                                <TextBlock x:Name="WebsiteEventNameLabelText" Foreground="{StaticResource TextMutedBrush}" />
                                <TextBox x:Name="WebsiteEventNameTextBox" Margin="0,6,0,10" />

                                <TextBlock x:Name="WebsiteFormatLabelText" Foreground="{StaticResource TextMutedBrush}" />
                                <ComboBox x:Name="WebsiteFormatComboBox" Margin="0,6,0,10">
                                    <ComboBoxItem Tag="original" Content="Original" />
                                    <ComboBoxItem Tag="strip-1x4" Content="1x4 Strip" />
                                    <ComboBoxItem Tag="grid-2x3" Content="2x3 Grid" />
                                    <ComboBoxItem Tag="grid-2x4" Content="2x4 Grid" />
                                </ComboBox>

                                <TextBlock x:Name="WebsiteVisibilityLabelText" Foreground="{StaticResource TextMutedBrush}" />
                                <ComboBox x:Name="WebsiteVisibilityComboBox" Margin="0,6,0,10" SelectionChanged="WebsiteVisibilityComboBox_SelectionChanged">
                                    <ComboBoxItem Tag="public" />
                                    <ComboBoxItem Tag="private" />
                                </ComboBox>

                                <TextBlock x:Name="WebsitePrivatePasswordLabelText" Foreground="{StaticResource TextMutedBrush}" />
                                <TextBox x:Name="WebsitePrivatePasswordTextBox" Margin="0,6,0,0" MaxLength="4" />
                            </StackPanel>
                        </Border>

                        <TextBlock x:Name="ApertureLabelText" Foreground="{StaticResource TextMutedBrush}" />
                        <ComboBox x:Name="ApertureComboBox" Margin="0,6,0,12" SelectionChanged="ParameterComboBox_SelectionChanged" Tag="aperture" />
                        <TextBlock x:Name="WhiteBalanceLabelText" Foreground="{StaticResource TextMutedBrush}" />
                        <ComboBox x:Name="WhiteBalanceComboBox" Margin="0,6,0,12" SelectionChanged="ParameterComboBox_SelectionChanged" Tag="whitebalance" />
                        <TextBlock x:Name="ExposureCompLabelText" Foreground="{StaticResource TextMutedBrush}" />
                        <ComboBox x:Name="ExposureCompComboBox" Margin="0,6,0,0" SelectionChanged="ParameterComboBox_SelectionChanged" Tag="exposurecompensation" />

                        <TextBlock x:Name="SelectedSourcesLabelText" Foreground="{StaticResource TextMutedBrush}" Margin="0,20,0,0" />
                        <TextBlock x:Name="SelectedSourcesText" Margin="0,8,0,0" TextWrapping="Wrap" />
                        <TextBlock x:Name="SessionProgressLabelText" Foreground="{StaticResource TextMutedBrush}" Margin="0,16,0,0" />
                        <TextBlock x:Name="SessionProgressText" Margin="0,8,0,0" FontWeight="SemiBold" TextWrapping="Wrap" />

                        <Border Background="{StaticResource PanelSoftBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="18" Padding="14" Margin="0,20,0,16">
                            <StackPanel>
                                <TextBlock x:Name="ActiveSessionLabelText" Foreground="{StaticResource TextMutedBrush}" FontSize="12" />
                                <TextBlock x:Name="ActiveSessionText" Margin="0,6,0,0" FontWeight="SemiBold" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Background="{StaticResource PanelSoftBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="18" Padding="14" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock x:Name="SelectSlotHintText" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Background="{StaticResource PanelSoftBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="18" Padding="14" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock x:Name="PhotoEditorTitleText" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock x:Name="PhotoEditorHintText" Margin="0,6,0,12" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" />

                                <TextBlock x:Name="EditablePhotoLabelText" Foreground="{StaticResource TextMutedBrush}" />
                                <ComboBox x:Name="EditablePhotoComboBox"
                                          Margin="0,6,0,10"
                                          SelectionChanged="EditablePhotoComboBox_SelectionChanged" />

                                <WrapPanel Margin="0,0,0,12">
                                    <Button x:Name="ReplaceEditablePhotoButton"
                                            Click="ReplaceEditablePhotoButton_Click"
                                            Margin="0,0,8,8"
                                            MinWidth="120" />
                                    <Button x:Name="DeleteEditablePhotoButton"
                                            Click="DeleteEditablePhotoButton_Click"
                                            Margin="0,0,0,8"
                                            MinWidth="120" />
                                </WrapPanel>

                                <TextBlock x:Name="AssignSlotLabelText" Foreground="{StaticResource TextMutedBrush}" />
                                <ComboBox x:Name="AssignSlotComboBox"
                                          Margin="0,6,0,8"
                                          SelectionChanged="AssignSlotComboBox_SelectionChanged" />

                                <WrapPanel Margin="0,0,0,12">
                                    <Button x:Name="MovePhotoPrevButton"
                                            Click="MovePhotoPrevButton_Click"
                                            Margin="0,0,8,8"
                                            MinWidth="120" />
                                    <Button x:Name="MovePhotoNextButton"
                                            Click="MovePhotoNextButton_Click"
                                            Margin="0,0,8,8"
                                            MinWidth="120" />
                                    <Button x:Name="ResetPhotoTransformButton"
                                            Click="ResetPhotoTransformButton_Click"
                                            Margin="0,0,0,8"
                                            MinWidth="120" />
                                </WrapPanel>

                                <TextBlock x:Name="ScaleLabelText" Foreground="{StaticResource TextMutedBrush}" />
                                <Slider x:Name="PhotoScaleSlider"
                                        Minimum="0.4"
                                        Maximum="2.4"
                                        TickFrequency="0.05"
                                        IsSnapToTickEnabled="False"
                                        Margin="0,6,0,6"
                                        ValueChanged="PhotoTransformSlider_ValueChanged" />
                                <TextBlock x:Name="ScaleValueText" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,10" />

                                <TextBlock x:Name="RotationLabelText" Foreground="{StaticResource TextMutedBrush}" />
                                <Slider x:Name="PhotoRotationSlider"
                                        Minimum="-90"
                                        Maximum="90"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="False"
                                        Margin="0,6,0,6"
                                        ValueChanged="PhotoTransformSlider_ValueChanged" />
                                <TextBlock x:Name="RotationValueText" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,10" />

                                <TextBlock x:Name="OffsetXLabelText" Foreground="{StaticResource TextMutedBrush}" />
                                <Slider x:Name="PhotoOffsetXSlider"
                                        Minimum="-0.6"
                                        Maximum="0.6"
                                        TickFrequency="0.01"
                                        IsSnapToTickEnabled="False"
                                        Margin="0,6,0,6"
                                        ValueChanged="PhotoTransformSlider_ValueChanged" />
                                <TextBlock x:Name="OffsetXValueText" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,10" />

                                <TextBlock x:Name="OffsetYLabelText" Foreground="{StaticResource TextMutedBrush}" />
                                <Slider x:Name="PhotoOffsetYSlider"
                                        Minimum="-0.6"
                                        Maximum="0.6"
                                        TickFrequency="0.01"
                                        IsSnapToTickEnabled="False"
                                        Margin="0,6,0,6"
                                        ValueChanged="PhotoTransformSlider_ValueChanged" />
                                <TextBlock x:Name="OffsetYValueText" Foreground="{StaticResource TextMutedBrush}" />
                            </StackPanel>
                        </Border>

                        <StackPanel Margin="0,20,0,0">
                            <TextBlock x:Name="DetectedDevicesTitleText" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock x:Name="DeviceSummaryText"
                                       Margin="0,6,0,0"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <ListBox x:Name="DevicesList"
                                 Margin="0,18,0,0"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{StaticResource TextBrush}" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
        </ScrollViewer>
    </Grid>
</Window>

